name: Telegram Alert

on:
  push:
    branches:
      - main

jobs:
  notify:
    runs-on: ubuntu-latest

    steps:
      - name: Send Alert
        run: |
          curl -s -X POST https://api.telegram.org/botYOUR_BOT_TOKEN/sendMessage \
          -d chat_id=YOUR_CHAT_ID \
          -d text="🚀 Deployment Done"
